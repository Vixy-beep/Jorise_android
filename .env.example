# Jorise v2 - Enterprise SOC
# Environment Variables Template

# Django
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=207.244.255.208,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://207.244.255.208,http://207.244.255.208:8000,http://localhost:3000
HTTPS_ENABLED=False

# Database
DB_NAME=jorise_db
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# AI Configuration (Primary: Google Gemini)
GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here  # Optional fallback

# Threat Intelligence
VIRUSTOTAL_API_KEY=your_virustotal_api_key
ALIENVAULT_API_KEY=your_alienvault_api_key

# Stripe (Payment Processing)
STRIPE_PUBLIC_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# CORS (Frontend URLs)
CORS_ALLOWED_ORIGINS=http://localhost:4321,http://localhost:3000

# Logging
DJANGO_LOG_LEVEL=INFO
